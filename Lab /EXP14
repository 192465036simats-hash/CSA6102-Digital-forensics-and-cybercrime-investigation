      "source": [
        "import re\n",
        "import pandas as pd\n",
        "\n",
        "sender=\"support@paypa1.com\"\n",
        "body=\"Verify now: http://paypa1-security-login.com/verify\"\n",
        "\n",
        "trusted=[\"paypal.com\",\"google.com\",\"microsoft.com\"]\n",
        "\n",
        "urls=re.findall(r'https?://[^\\s]+',body)\n",
        "sender_domain=sender.split(\"@\")[1]\n",
        "\n",
        "data=[]\n",
        "\n",
        "for url in urls:\n",
        "    domain=url.split(\"//\")[1].split(\"/\")[0]\n",
        "    suspicious=(domain not in trusted) or any(c.isdigit() for c in domain)\n",
        "    data.append([url,domain,suspicious])\n",
        "\n",
        "risk=50 if sender_domain not in trusted else 0\n",
        "risk+=20*len(urls)\n",
        "\n",
        "df=pd.DataFrame(data,columns=[\"URL\",\"Domain\",\"Suspicious\"])\n",
        "print(\"Risk Score:\",risk)\n",
        "print(df)\n",
        "\n",
        "df.to_csv(\"phishing_report.csv\",index=False)"
      ]
    }
