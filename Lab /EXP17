      "source": [
        "import pandas as pd\n",
        "\n",
        "attempts=[\"admin\",\"123456\",\"password\",\"admin123\"]\n",
        "correct=\"admin123\"\n",
        "\n",
        "logs=[]\n",
        "\n",
        "for a in attempts:\n",
        "    logs.append([a,\"Success\" if a==correct else \"Failed\"])\n",
        "\n",
        "df=pd.DataFrame(logs,columns=[\"Attempt\",\"Result\"])\n",
        "print(df)\n",
        "\n",
        "payloads=[\"' OR '1'='1\",\"admin' --\",\"normaluser\"]\n",
        "\n",
        "for p in payloads:\n",
        "    if \"' OR\" in p.upper() or \"--\" in p:\n",
        "        print(\"SQL Injection Detected:\",p)\n",
        "\n",
        "paths=[\"../../etc/passwd\",\"../admin/config\",\"/home/user\"]\n",
        "\n",
        "for p in paths:\n",
        "    if \"../\" in p:\n",
        "        print(\"Directory Traversal Detected:\",p)\n",
        "\n",
        "df.to_csv(\"attack_logs.csv\",index=False)"
      ]
