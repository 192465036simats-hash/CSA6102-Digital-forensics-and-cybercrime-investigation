        "import datetime\n",
        "def investigation_report(case_id, evidence_list):\n",
        "    stages = {\n",
        "        \"Identification\": f\"Incident reported for case {case_id}. Devices/logs\\nidentified for review.\",\n",
        "        \"Collection\": f\"{len(evidence_list)} item(s) collected: {',\\n'.join(evidence_list)}\",\n",
        "        \"Preservation\": \"All items hashed (SHA-256) and stored in a write-protected\\nevidence folder.\",\n",
        "        \"Analysis\": \"Log files and file metadata examined for indicators of\\ncompromise.\",\n",
        "        \"Reporting\": \"Findings compiled into a structured forensic report for legal\\nreview.\",\n",
        "    }\n",
        "    print(f\"=== Investigation Lifecycle: Case {case_id} ===\")\n",
        "    print(f\"Generated: {datetime.datetime.now()}\\n\")\n",
        "    for stage, detail in stages.items():\n",
        "        print(f\"[{stage}]\")\n",
        "        print(f\" {detail}\\n\")\n",
        "investigation_report(\"CASE-2026-014\", [\"laptop_disk_image.dd\", \"router_traffic.pcap\",\n",
        "\"email_headers.txt\"])"
      ]
